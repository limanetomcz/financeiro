APP_NAME=Financeiro
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8085

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=financeiro
DB_USERNAME=financeiro
DB_PASSWORD=financeiro

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6380
REDIS_DB=0
REDIS_CACHE_DB=1

# Filas multi-tenant (ver docs/filas-redis.md)
FINANCEIRO_QUEUE_POR_CLIENTE=false
FINANCEIRO_QUEUE_DEFAULT=default
FINANCEIRO_QUEUE_COBRANCA=cobranca
FINANCEIRO_QUEUE_BANCARIO=bancario
FINANCEIRO_LAB_LIMPEZA=true
FINANCEIRO_AUDITORIA_FUSCA=false

MAIL_MAILER=log
MAIL_FROM_ADDRESS="financeiro@localhost"
MAIL_FROM_NAME="${APP_NAME}"

# Mesmo JWT_SECRET do sigo-laravel da instalação (não versionar o valor real)
SIGOWEB_JWT_SECRET=
SIGOWEB_JWT_ALGO=HS256

# Base URL do sigo-laravel (Financeiro busca composição da fatura PJ)
# Ex.: http://host.docker.internal/sigo-laravel/public
SIGO_LARAVEL_URL=

# Origens do Sigoweb (browser). Em produção, liste hosts; local pode usar *
FINANCEIRO_CORS_ORIGINS=*

VITE_APP_NAME="${APP_NAME}"
